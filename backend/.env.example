# Copia questo file in backend/.env (non committare). Su Railway: Variables del servizio backend.
#
# Migrazioni DB da PC: con DATABASE_URL qui sotto, nella cartella backend esegui solo: npm run migrate

PORT=8787

# Stessa stringa Neon (Connection string con sslmode=require) — UNA SOLA RIGA, tra virgolette se serve
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Clerk → API Keys → Secret key (mai nel frontend)
CLERK_SECRET_KEY=sk_test_xxxxxxxx

# Origini CORS separate da virgola (es. https://www.nonsolotarocchi.it,http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# Calendly → Webhooks → signing key (verifica firma HMAC)
CALENDLY_WEBHOOK_SIGNING_KEY=

# Solo sviluppo locale: accetta webhook senza verificare la firma (non usare in produzione)
# CALENDLY_SKIP_SIGNATURE_VERIFY=true
